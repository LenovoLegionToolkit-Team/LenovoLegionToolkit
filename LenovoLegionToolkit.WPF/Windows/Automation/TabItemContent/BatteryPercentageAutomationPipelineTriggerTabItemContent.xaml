<UserControl
    x:Class="LenovoLegionToolkit.WPF.Windows.Automation.TabItemContent.BatteryPercentageAutomationPipelineTriggerTabItemContent"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:resources="clr-namespace:LenovoLegionToolkit.WPF.Resources"
    xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
    Padding="12"
    Initialized="BatteryPercentageAutomationPipelineTriggerTabItemContent_Initialized">

    <StackPanel>
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <TextBlock
                Grid.Column="0"
                Margin="0,0,12,0"
                VerticalAlignment="Center"
                Text="{Binding Source={x:Static resources:Resource.BatteryPercentageAutomationPipelineTriggerTabItemContent_Percentage}}" />

            <ui:NumberBox
                x:Name="_percentageValuePicker"
                Grid.Column="1"
                Margin="0,0,8,0"
                VerticalAlignment="Center"
                ClearButtonEnabled="False"
                MaxDecimalPlaces="0"
                Maximum="100"
                Minimum="0" />

            <ComboBox
                x:Name="_comparisonComboBox"
                Grid.Column="2"
                Width="150"
                VerticalAlignment="Center"
                SelectedIndex="0">
                <ComboBoxItem Content="{Binding Source={x:Static resources:Resource.BatteryPercentageAutomationPipelineTriggerTabItemContent_Below}}" />
                <ComboBoxItem Content="{Binding Source={x:Static resources:Resource.BatteryPercentageAutomationPipelineTriggerTabItemContent_Above}}" />
            </ComboBox>
        </Grid>
    </StackPanel>
</UserControl>
